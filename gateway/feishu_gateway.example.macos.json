    "*"
  ],
  "groupAllowFrom": [
    "*"
  ],
  "requireMentionInGroups": false,
  "groupSessionScope": "group_sender",
  "groupAssistantMode": "hybrid",
  "groupPublicMemoryLimit": 24,
  "groupHighlightLimit": 12,
