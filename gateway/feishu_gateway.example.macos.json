{
  "appId": "cli_your_feishu_app_id",
  "appSecret": "your_feishu_app_secret",
  "botName": "Codex Bot",
  "domain": "feishu",
  "workspace": "<WORKSPACE_ROOT>",
  "codexBin": "codex",
  "codexSessionsRoot": "<CODEX_HOME>/sessions",
