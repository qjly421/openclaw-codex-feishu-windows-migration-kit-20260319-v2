  "startupNotifyDeduplicatePerBoot": true,
  "startupMorningBriefEnabled": false,
  "startupMorningBriefChatIds": [],
  "startupMorningBriefMaxItems": 4,
  "startupMorningBriefMaxAgeDays": 5,
  "startupMorningBriefDeduplicateDaily": true,
  "startupMorningBriefTimeZone": "Asia/Shanghai",
  "replyChunkLimit": 1800,
  "codexTimeoutMs": 3600000,
  "codexFirstEventTimeoutMs": 180000,
  "codexArgs": [],
  "mediaRoot": "<RUNTIME_ROOT>/media"
